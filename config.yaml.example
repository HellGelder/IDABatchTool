# Конфигурация IDA Batch Tool.
# Скопируйте этот файл в config.yaml и укажите актуальные пути.

# Путь к исполняемому файлу IDA Pro 9.0+ (idat).
# Можно указать абсолютный путь или просто имя «idat» (тогда поиск выполнится в PATH
# и в типичных папках установки).
ida:
  executable: idat

# Путь к исполняемому файлу BinDiff.
# Если «bindiff» (или «bindiff.exe» на Windows) доступен в PATH, можно оставить как есть.
# Иначе укажите абсолютный путь или поместите bindiff.exe рядом с этим файлом.
bindiff:
  executable: bindiff

# Каталог для анализа по умолчанию (CLI и плейсхолдер в GUI).
default_inputdir: .

# Максимальное количество параллельных экземпляров IDA.
max_ida: 4

# Уровень логирования: DEBUG / INFO / WARNING / ERROR.
log_level: INFO

# Тема интерфейса: light / dark.
theme: light

# Путь к папке хранения локальных БД сигнатур (например, win32api.db).
sf_db_path: databases
